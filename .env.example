APP_NAME=ArogyaKart
# PRODUCTION: set APP_ENV=production and APP_DEBUG=false. Leaving debug on in
# production leaks stack traces (and DB credentials) to end users.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# PRODUCTION: set to your real HTTPS domain, e.g. https://app.yourpharmacy.com
APP_URL=http://localhost

# Seed password for the demo admin (php artisan db:seed). Change before go-live.
ADMIN_PASSWORD=Admin@12345

# Platform owner (Super Admin) seed credentials. Change before go-live.
SUPER_ADMIN_EMAIL=superadmin@pharmaflow.com
SUPER_ADMIN_PASSWORD=Super@12345

# ---- SaaS / Subscription settings ----
SAAS_TRIAL_DAYS=14
SAAS_GST_PERCENT=18
SAAS_CURRENCY=INR

# ---- Razorpay payment gateway ----
# Get keys from https://dashboard.razorpay.com/app/keys . Leave blank for local
# dev — the app falls back to activating plans without charging.
RAZORPAY_KEY=
RAZORPAY_SECRET=
# Set this to the secret you configure on the Razorpay webhook (event: payment.captured)
# pointing at https://YOUR_DOMAIN/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=my-db
DB_USERNAME=root
DB_PASSWORD=


SESSION_DRIVER=database
SESSION_LIFETIME=120
# PRODUCTION: set SESSION_ENCRYPT=true and SESSION_SECURE_COOKIE=true (HTTPS only).
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
