# =============================================================================
# ArogyaKart — PRODUCTION environment template
# =============================================================================
# HOW TO USE
#   1.  cp .env.production.example .env
#   2.  Fill every value marked CHANGE_ME (never commit the resulting .env).
#   3.  php artisan key:generate --force        # sets APP_KEY
#   4.  php artisan config:cache                 # after editing, re-cache
#
# SECURITY: this file must never contain real secrets. It is a template only.
# The live .env is git-ignored — keep it that way.
# =============================================================================

# ---- Application ------------------------------------------------------------
APP_NAME=ArogyaKart
APP_ENV=production
# CRITICAL: never true in production — debug leaks stack traces & DB credentials.
APP_DEBUG=false
APP_KEY=
# Your real HTTPS domain. Must be https:// so secure cookies & links work.
APP_URL=https://app.yourpharmacy.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Platform maintenance flag store (file is fine for a single server).
APP_MAINTENANCE_DRIVER=file

# Higher = stronger password hashing (and slower). 12 is a sane production value.
BCRYPT_ROUNDS=12

# ---- Logging ----------------------------------------------------------------
# 'daily' rotates logs; the app's error reporter also writes to this channel.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Only record warnings and above in production; 'debug' is far too noisy/leaky.
LOG_LEVEL=warning

# ---- Seed credentials (rotate BEFORE go-live) -------------------------------
# Prefer letting the pharmacist self-register over seeding a demo admin. If you
# DO seed, set strong unique passwords here first, then rotate after first login.
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SUPER_ADMIN_EMAIL=owner@yourcompany.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_SUPERADMIN_PASSWORD

# ---- Database (MySQL 8) -----------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=arogya_kart
DB_USERNAME=arogya
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ---- Sessions (hardened for HTTPS) ------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Encrypt session payloads at rest.
SESSION_ENCRYPT=true
# Only transmit the session cookie over HTTPS. Requires a real TLS cert.
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
# Set to your domain (e.g. .yourpharmacy.com) to scope the cookie; null is OK.
SESSION_DOMAIN=null

# ---- Cache & Queue ----------------------------------------------------------
# 'database' works out of the box. Switch both to redis if a Redis server is
# available for better throughput.
CACHE_STORE=database
QUEUE_CONNECTION=database
# NOTE: QUEUE_CONNECTION=database REQUIRES a running worker
#   (Supervisor: `php artisan queue:work`). Without it, queued PDF exports and
#   notifications never process. See DEPLOYMENT.md §7.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---- Redis (optional; only if CACHE_STORE/QUEUE_CONNECTION=redis) -----------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- Mail (real SMTP — password resets & alerts depend on this) -------------
# MAIL_MAILER=log silently discards mail. Use a real transactional provider.
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_SCHEME=tls
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=no-reply@yourpharmacy.com
MAIL_FROM_NAME="${APP_NAME}"

# ---- SaaS / Subscription ----------------------------------------------------
SAAS_TRIAL_DAYS=14
SAAS_GST_PERCENT=18
SAAS_CURRENCY=INR

# ---- Razorpay payment gateway -----------------------------------------------
# Live keys from https://dashboard.razorpay.com/app/keys .
# If left blank, subscriptions activate WITHOUT charging (dev fallback) — never
# ship to production with these empty if you intend to bill customers.
RAZORPAY_KEY=CHANGE_ME
RAZORPAY_SECRET=CHANGE_ME
# The secret configured on the Razorpay webhook (event: payment.captured),
# pointing at https://YOUR_DOMAIN/webhooks/razorpay . Verifies webhook signatures.
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

# ---- Pharmacy display / operations ------------------------------------------
PHARMACY_CURRENCY_SYMBOL=₹
PHARMACY_CURRENCY_CODE=INR
PHARMACY_DATE_FORMAT="d M Y"
PHARMACY_DATETIME_FORMAT="d M Y, H:i"
PHARMACY_EXPIRY_ALERT_DAYS=30
PHARMACY_LOW_STOCK_DEFAULT=10
# Days of DB backups to retain before pharmacy:backup prunes them.
PHARMACY_BACKUP_RETENTION_DAYS=30

# ---- Frontend build ---------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
